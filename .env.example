# PRism-AI Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
BASE_URL=http://localhost:8000

# ── LLM Backend ──────────────────────────────────────────────────────────────
# Choose: ollama | ollama_cloud | vertex | bedrock | openai
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=180

# ── Ollama (Local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_FALLBACK_MODEL=qwen2.5-coder

# ── Ollama Cloud ─────────────────────────────────────────────────────────────
# OLLAMA_CLOUD_URL=https://api.ollama.ai/v1
# OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key
# OLLAMA_CLOUD_MODEL=llama3.1
# OLLAMA_CLOUD_ENABLED=true

# ── Google Vertex AI ─────────────────────────────────────────────────────────
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-pro
# Option A: service account JSON (base64 encoded or path)
# VERTEX_SERVICE_ACCOUNT_JSON=/secrets/gcp-sa.json
# Option B: Workload Identity (GKE)
# VERTEX_USE_WORKLOAD_IDENTITY=true

# ── AWS Bedrock ──────────────────────────────────────────────────────────────
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# Option A: IAM access keys
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# Option B: IAM role ARN (cross-account)
# BEDROCK_ROLE_ARN=arn:aws:iam::123456789:role/PrismAIRole

# ── OpenAI / Compatible ──────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# For local LLM servers (LM Studio, vLLM, etc.):
# OPENAI_API_BASE=http://localhost:1234/v1
# OPENAI_API_KEY=not-needed

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# For GitHub Enterprise:
# GITHUB_API_URL=https://github.your-company.com/api/v3
# GitHub App (optional - stronger auth)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# ── GitLab ───────────────────────────────────────────────────────────────────
# GITLAB_TOKEN=glpat-your_token
# GITLAB_WEBHOOK_SECRET=your_webhook_secret
# For self-hosted GitLab:
# GITLAB_URL=https://gitlab.your-company.com
# GITLAB_SSL_VERIFY=true

# ── Gitea (intranet) ─────────────────────────────────────────────────────────
# GITEA_TOKEN=your_gitea_token
# GITEA_URL=http://gitea:3000
# GITEA_WEBHOOK_SECRET=your_webhook_secret

# ── Bitbucket ────────────────────────────────────────────────────────────────
# BITBUCKET_TOKEN=your_token
# BITBUCKET_WORKSPACE=your_workspace

# ── Agent Behaviour ──────────────────────────────────────────────────────────
AUTO_REVIEW_ON_OPEN=true
AUTO_DESCRIBE_ON_OPEN=true
AUTO_LABEL_ON_OPEN=true
AUTO_SECURITY_ON_OPEN=true
INLINE_COMMENTS=true
COLLAPSE_SUGGESTIONS=true

# ── Policy / RBAC ────────────────────────────────────────────────────────────
RBAC_ENABLED=true
POLICY_FILE=policy.yaml

# ── Notifications ────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
NOTIFY_ON_HIGH_SEVERITY=true

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./prism_ai.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@db:5432/prismdb
# REDIS_URL=redis://redis:6379/0

# ── Observability ────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/project
