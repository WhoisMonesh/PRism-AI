DEBUG=false
HOST=0.0.0.0
PORT=8000

GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_BASE_URL=https://api.github.com

GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret_here
GITLAB_TOKEN=glpat_your_gitlab_token_here
GITLAB_BASE_URL=https://gitlab.com

GITEA_WEBHOOK_SECRET=your_gitea_webhook_secret_here
GITEA_TOKEN=your_gitea_token_here
GITEA_BASE_URL=https://gitea.com

BITBUCKET_WEBHOOK_SECRET=your_bitbucket_webhook_secret_here
BITBUCKET_TOKEN=your_bitbucket_token_here
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0

LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

OLLAMA_CLOUD_URL=https://api.ollama.cloud/v1
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_CLOUD_MODEL=llama3.1

VERTEX_PROJECT_ID=your_gcp_project_id_here
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-pro
VERTEX_CREDENTIALS_PATH=/secrets/gcp-sa.json

BEDROCK_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/bedrock-pr-reviewer

OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

AUTO_REVIEW_ON_PR=false
MIN_APPROVAL_SCORE=70

POLICY_FILE=policy.yaml

CORS_ORIGINS=["http://localhost:5173","http://localhost:8000","http://localhost:3000"]
